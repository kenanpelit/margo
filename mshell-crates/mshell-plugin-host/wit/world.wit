// mplugins WASM tier — host/guest contract.
//
// W2 adds the UI model + event loop. The guest renders a UI as a *flat list*
// of nodes (each node names its children by id) — the component model has no
// recursive types, so the host reconstructs the tree from the list, rooted at
// the node with id "root". `view` is the initial render; `update(event)`
// re-renders after an interaction. Capabilities beyond `log` (settings, http,
// notify) arrive in W3.

package margo:plugin;

interface types {
    enum node-kind {
        vbox,
        hbox,
        label,
        button,
        entry,
        /// A vertically-scrolling container for its children — e.g. a chat log.
        scroll,
        /// A label whose text is lightweight markdown (bold/italic/`code`),
        /// styled as a message bubble. `text` carries the markdown source.
        markdown,
        /// An image, loaded from a file path or a freedesktop icon name. The
        /// source goes in `text`; symbolic icon names get matugen-tinted.
        image,
        /// A bool switch (`gtk::Switch`). Initial state via `properties["on"]`;
        /// toggling echoes a `click` event whose `value` is "true" / "false".
        switch,
        /// A numeric slider (`gtk::Scale`). `properties` carries
        /// `min`/`max`/`value`/`step`; dragging echoes an `input` event whose
        /// `value` is the new number formatted as a string.
        slider,
        /// A determinate progress bar. `properties["fraction"]` is 0.0–1.0.
        progress,
        /// A visual divider that respects the design language's spacing.
        separator,
        /// A two-dimensional grid (`gtk::Grid`). `properties["columns"]` sets
        /// the column count; children flow row-major.
        grid,
        /// A `gtk::Revealer` holding one child. `properties["revealed"]`
        /// toggles the animation; `properties["transition"]` picks the curve
        /// (`slide-down`/`slide-up`/`crossfade`/…).
        revealer,
        /// A `gtk::Stack` switching between named children.
        /// `properties["visible-child"]` is one of the children's ids.
        stack,
        /// Future-proof escape hatch. Any new node kind we add *after* this
        /// one rides on top of `extended` rather than growing the enum, so
        /// pre-compiled plugins keep instantiating against new hosts. The
        /// renderer dispatches on `properties["kind"]` (e.g. `"calendar"`,
        /// `"tree-view"`, …); unknown kinds render as an empty box.
        extended,
    }

    record node {
        /// Unique within a render; "root" is the tree root. Buttons/entries
        /// use it to tag the events they emit.
        id: string,
        kind: node-kind,
        /// Label/button caption, an entry's current text, an image's source, …
        text: string,
        /// Child node ids, in order (ignored for leaf kinds).
        children: list<string>,
        /// Optional space-separated CSS classes the host adds to the rendered
        /// widget, so a plugin can opt into the design language's styling
        /// (e.g. `plugin-hero`, `plugin-action`, `plugin-toggle`). Empty = none.
        class: string,
        /// Extensible property bag — every per-node knob the renderer reads
        /// (layout: `padding`/`margin`/`spacing`/`halign`/`valign`/`hexpand`/
        /// `vexpand`/`width`/`height`; per-kind: `on`, `fraction`, `min`/
        /// `max`/`value`/`step`, …) goes through this map so future
        /// extensions don't break pre-compiled plugins.
        properties: list<tuple<string, string>>,
    }

    enum event-kind {
        click,
        input,
        submit,
        /// A chunk of an `http-start` response body. `id` is the request id
        /// returned by `http-start`; `value` is the chunk's bytes (lossy utf-8).
        stream-chunk,
        /// An `http-start` stream finished. `id` is the request id; on failure
        /// `value` carries an `error: …` message.
        stream-end,
        /// A global keyboard shortcut the plugin registered through its
        /// manifest's `[[keybind]]` table fired. `id` is the binding's id
        /// from the manifest; `value` is empty.
        keybind,
        /// Future-proof escape hatch: any new event variant added *after*
        /// this one rides on `extended` with `id` formatted as
        /// `<kind>:<actual-id>` so pre-compiled plugins don't break when
        /// the event taxonomy grows. The renderer dispatches on the prefix.
        extended,
    }

    record event {
        /// Id of the node — or, for stream events, the request — that produced it.
        id: string,
        kind: event-kind,
        /// Entry text for input/submit; a body chunk for stream-chunk; else empty.
        value: string,
    }
}

/// Host capabilities the guest may call — these *are* the sandbox boundary:
/// the guest can do nothing the host doesn't expose here. W2 shipped logging;
/// W3 adds settings, notifications, and one-shot HTTP. Streaming HTTP is W4.
interface host {
    /// Structured logging (0=trace…4=error).
    log: func(level: u32, message: string);

    /// Read a value the user set for this plugin (the declarative `[[setting]]`
    /// tier — same store as the bar-pill plugins). Empty string if unset.
    get-setting: func(key: string) -> string;

    /// Post a desktop notification on the plugin's behalf. Best-effort.
    notify: func(summary: string, body: string);

    /// Copy text to the system clipboard (Wayland `wl-copy`). Best-effort.
    copy: func(text: string);

    /// Read the current Wayland clipboard text. Empty on any failure (no
    /// clipboard, binary data, …). Pair with `copy` to round-trip.
    clipboard-read: func() -> string;

    /// Read a file from the plugin's own storage. `rel-path` is interpreted
    /// against the plugin's data dir (`$XDG_DATA_HOME/mshell/plugins/<key>`)
    /// — escaping it via `..` is rejected. Returns the file bytes or an
    /// error message.
    read-file: func(rel-path: string) -> result<list<u8>, string>;

    /// Write a file to the plugin's data dir, creating it if necessary.
    /// Same scoping rules as `read-file`. Atomic-ish: writes to a tmp file
    /// and renames into place so a crash mid-write doesn't corrupt the
    /// existing file.
    write-file: func(rel-path: string, bytes: list<u8>) -> result<_, string>;

    /// Run a program with args (no shell) and return its output. Blocking, so
    /// only for fast commands (status / toggles / control CLIs). This is the
    /// same trust level as the declarative tier's shell commands — it lets a
    /// WASM panel drive a system tool (e.g. `mullvad`).
    run: func(program: string, args: list<string>) -> process-output;

    record process-output {
        stdout: string,
        stderr: string,
        /// Exit code, or -1 if the process couldn't be spawned/waited.
        code: s32,
    }

    /// One outbound HTTP request → full response (non-streaming). The host —
    /// not the guest — performs the network I/O; this is the only egress the
    /// guest gets. For token streams use `http-start` instead.
    http: func(req: http-request) -> result<http-response, string>;

    /// Currently-playing media (MPRIS), the way the shell's media widget sees
    /// it. Empty strings everywhere when no player is active.
    media-now-playing: func() -> media-info;

    record media-info {
        /// MPRIS player identifier, e.g. `"spotify"`. `""` when none.
        player: string,
        title: string,
        artist: string,
        album: string,
        /// Cover art URL (`file://…` or `https://…`). `""` when none.
        art-url: string,
        /// `"playing"` | `"paused"` | `"stopped"` | `""`.
        status: string,
        position-ms: u64,
        length-ms: u64,
    }

    /// System-level live state — battery, network, idle. Same trust level as
    /// the rest of the host caps (read-only snapshot of values the shell
    /// already exposes through wayle).
    system-state: func() -> system-info;

    record system-info {
        /// Battery percentage 0–100, or 255 if no battery.
        battery-pct: u8,
        /// `"charging"` | `"discharging"` | `"full"` | `"unknown"`.
        battery-status: string,
        /// `"wifi"` | `"ethernet"` | `"none"`.
        network-kind: string,
        /// Wi-Fi SSID when `network-kind == "wifi"`; `""` otherwise.
        network-ssid: string,
        /// Milliseconds since the last user input. 0 if unavailable.
        idle-ms: u64,
    }

    /// Begin a subprocess asynchronously and return immediately with a request
    /// id. The child's stdout is read off the UI thread and delivered as
    /// `stream-chunk` events (then one `stream-end`) keyed by that id — same
    /// shape as `http-start`, so a guest can tail `journalctl -f`, `tail -F`,
    /// a long-running build, etc., without blocking the UI.
    process-start: func(program: string, args: list<string>) -> string;

    /// Begin a request asynchronously and return immediately with a request
    /// id. The response body is read off the UI thread and delivered back as
    /// `stream-chunk` events (then one `stream-end`) to `update`, keyed by that
    /// id — so a token stream never blocks the UI. The host drains pending
    /// chunks from its main loop.
    http-start: func(req: http-request) -> string;

    record http-request {
        /// "GET", "POST", … Defaults to GET if empty.
        method: string,
        url: string,
        /// Header name/value pairs.
        headers: list<tuple<string, string>>,
        /// Request body; empty for GET.
        body: string,
    }

    record http-response {
        status: u16,
        body: string,
    }
}

/// The plugin's exported UI entry points. (An interface, not bare world
/// functions, so the authoring SDK's `export!` macro works across crates.)
interface guest {
    use types.{node, event};

    /// Initial UI, as a flat node list rooted at id "root".
    view: func() -> list<node>;
    /// Re-render after an interaction; returns the new flat node list.
    update: func(ev: event) -> list<node>;
}

world plugin {
    import host;
    export guest;
}
