// mplugins WASM tier — host/guest contract.
//
// VENDORED COPY for the authoring SDK. Keep this byte-for-byte in sync with
// mshell-crates/mshell-plugin-host/wit/world.wit (the canonical host copy) —
// the SDK must generate against the exact contract the host links.
//
// The guest renders a UI as a *flat list* of nodes (each node names its
// children by id) — the component model has no recursive types, so the host
// reconstructs the tree from the list, rooted at the node with id "root".
// `view` is the initial render; `update(event)` re-renders after an event.

package margo:plugin;

interface types {
    enum node-kind {
        vbox,
        hbox,
        label,
        button,
        entry,
        /// A vertically-scrolling container for its children — e.g. a chat log.
        scroll,
        /// A label whose text is lightweight markdown (bold/italic/`code`),
        /// styled as a message bubble. `text` carries the markdown source.
        markdown,
    }

    record node {
        /// Unique within a render; "root" is the tree root. Buttons/entries
        /// use it to tag the events they emit.
        id: string,
        kind: node-kind,
        /// Label/button caption, or an entry's current text.
        text: string,
        /// Child node ids, in order (ignored for leaf kinds).
        children: list<string>,
    }

    enum event-kind {
        click,
        input,
        submit,
        /// A chunk of an `http-start` response body. `id` is the request id
        /// returned by `http-start`; `value` is the chunk's bytes (lossy utf-8).
        stream-chunk,
        /// An `http-start` stream finished. `id` is the request id; on failure
        /// `value` carries an `error: …` message.
        stream-end,
    }

    record event {
        /// Id of the node — or, for stream events, the request — that produced it.
        id: string,
        kind: event-kind,
        /// Entry text for input/submit; a body chunk for stream-chunk; else empty.
        value: string,
    }
}

/// Host capabilities the guest may call — these *are* the sandbox boundary:
/// the guest can do nothing the host doesn't expose here. W2 shipped logging;
/// W3 adds settings, notifications, and one-shot HTTP. Streaming HTTP is W4.
interface host {
    /// Structured logging (0=trace…4=error).
    log: func(level: u32, message: string);

    /// Read a value the user set for this plugin (the declarative `[[setting]]`
    /// tier — same store as the bar-pill plugins). Empty string if unset.
    get-setting: func(key: string) -> string;

    /// Post a desktop notification on the plugin's behalf. Best-effort.
    notify: func(summary: string, body: string);

    /// Copy text to the system clipboard (Wayland `wl-copy`). Best-effort.
    copy: func(text: string);

    /// Run a program with args (no shell) and return its output. Blocking, so
    /// only for fast commands (status / toggles / control CLIs). This is the
    /// same trust level as the declarative tier's shell commands — it lets a
    /// WASM panel drive a system tool (e.g. `mullvad`).
    run: func(program: string, args: list<string>) -> process-output;

    record process-output {
        stdout: string,
        stderr: string,
        /// Exit code, or -1 if the process couldn't be spawned/waited.
        code: s32,
    }

    /// One outbound HTTP request → full response (non-streaming). The host —
    /// not the guest — performs the network I/O; this is the only egress the
    /// guest gets. For token streams use `http-start` instead.
    http: func(req: http-request) -> result<http-response, string>;

    /// Begin a request asynchronously and return immediately with a request
    /// id. The response body is read off the UI thread and delivered back as
    /// `stream-chunk` events (then one `stream-end`) to `update`, keyed by that
    /// id — so a token stream never blocks the UI. The host drains pending
    /// chunks from its main loop.
    http-start: func(req: http-request) -> string;

    record http-request {
        /// "GET", "POST", … Defaults to GET if empty.
        method: string,
        url: string,
        /// Header name/value pairs.
        headers: list<tuple<string, string>>,
        /// Request body; empty for GET.
        body: string,
    }

    record http-response {
        status: u16,
        body: string,
    }
}

/// The plugin's exported UI entry points. (An interface, not bare world
/// functions, so the authoring SDK's `export!` macro works across crates.)
interface guest {
    use types.{node, event};

    /// Initial UI, as a flat node list rooted at id "root".
    view: func() -> list<node>;
    /// Re-render after an interaction; returns the new flat node list.
    update: func(ev: event) -> list<node>;
}

world plugin {
    import host;
    export guest;
}
