_mshellctl_commands() {
    local commands; commands=(
'quit:Quit the shell process — bars and menus disappear, but the compositor (margo) keeps running' \
'inspect:Open the GTK4 inspector — handy for finding CSS node names and classes while styling' \
'set-wallpaper:Set the wallpaper to a specific image (one-shot). Use \`wallpaper\` to cycle through a directory instead' \
'menu:Open, close, or toggle a shell menu (control-center, mdash, clipboard, …)' \
'bar:Show, hide, or toggle the top and bottom bars' \
'hidden-bar:Control a Hidden Bar drawer widget. With no \`name\`, the verb reaches every drawer; pass a \`name\` to target one named drawer (a \`bars.widgets.hidden_bars\` entry, placed via \`!HiddenBarNamed <name>\`)' \
'audio:Audio control — output/input volume, mute, and device switching' \
'bluetooth:Bluetooth auto-connect engine\: toggle / connect / disconnect the configured device(s). Bind \`bluetooth toggle\` to F10 to replace the old bluetooth_toggle script' \
'media:Control the active MPRIS media player — play/pause, next, previous' \
'brightness:Backlight brightness — raise, lower, or set a level' \
'log:Shell file-logging controls (~/.local/state/margo/logs/mshell-*.log). \`level\`/\`enable\`/\`disable\` retune the running shell live' \
'dock:Standalone mdock surface — toggle / show / hide' \
'lock:Lock the session. Bare \`lock\` locks; \`lock check\` reports state' \
'session:Session / power actions — lock, logout, suspend, reboot, shutdown, or open the session menu. Bind \`session logout\` to a key to replace a wlogout/rofi script' \
'notification:Notification centre — open the panel, clear, dismiss popups, toggle Do Not Disturb, or print the history count' \
'settings:Open or close the Settings window' \
'wizard:Open the in-shell setup wizard (a layer-shell menu)' \
'wallpaper:Cycle the wallpaper — next, previous, or random' \
'theme:Colour scheme — list, show, or switch the active scheme live (the same picker as Settings → Theme → Color Scheme; no restart)' \
'plugin:Manage installed WASM plugins (reload from disk, …)' \
'screenshot:Capture a screenshot — region / window / output / full, delivered to file + clipboard (or \`--copy\` / \`--save\` / \`--edit\`). Drives the shell'\''s own screenshot engine (same path as the screenshot menu)' \
'screenrecord:Screen recording — start / stop / toggle. Drives the shell'\''s own recording engine (same as the screenshot menu'\''s recording section)' \
'clipboard:Clipboard history — list / copy / pin / delete / clear / wipe. Drives the same store as \`mshellctl menu clipboard\`' \
'toast:Show a transient state-change toast — the \`notify-send\` equivalent for the toast surface. Ephemeral (no notification history); usable from scripts and startup services' \
'gamemode:Game Mode — drop compositor effects, silence notifications, and keep the session awake while gaming. Configure what it affects in Settings → Game Mode' \
'calendar:Calendar — today'\''s / upcoming events and connected accounts (proxied to the \`mcal\` calendar tool). \`calendar account setup google\` connects a Google account' \
'vpn:Mullvad VPN control — connect / disconnect / pick a relay (proxied to \`mvpn\`). Use \`vpn menu\` for the shell'\''s DNS/VPN panel' \
'power:Power-profile control — status / cycle / set / pause / resume (proxied to the \`mpower\` daemon). Use \`menu power\` for the panel' \
'layout:Saved tiling-layout snapshots — list / set / next / prev / preview (proxied to \`mlayout\`)' \
'osk:On-screen keyboard — show / hide / toggle (proxied to \`mkeys\`)' \
'color:Pick a screen colour (proxied to \`mpicker\`) — prints the colour; use \`--copy\` / \`--notify\` / \`--format\`' \
'play:mpv companion — play / toggle / stop / snapshot / video wallpaper (proxied to \`mplay\`)' \
'doctor:Health check — is the shell on the session bus, is it the same version as this \`mshellctl\`, are its key services up. Run \`mctl doctor\` for the compositor side' \
'completions:Generate a shell-completion script (bash / zsh / fish / …) to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'mshellctl commands' commands "$@"
}
