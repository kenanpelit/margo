{"nodes": [{"id": "start_margo_readme_start_margo", "label": "start-margo (compositor watchdog supervisor)", "file_type": "document", "source_file": "start-margo/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Event-driven single poll(2) over signalfd + child pidfd + readiness pipe (zero idle CPU). Crash budget + exponential backoff avoids pinning CPU on a broken config; sd_notify WATCHDOG=1 keep-alives let systemd recover a hung compositor, not just a crashed one; signal-preserving forwarding guarantees margo teardown always runs. PR_SET_PDEATHSIG(SIGKILL) shared with start-hyprland."}, {"id": "start_margo_readme_sd_notify", "label": "sd_notify readiness protocol (READY/WATCHDOG/STOPPING/FATAL)", "file_type": "concept", "source_file": "start-margo/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "start_margo_readme_start_margo", "target": "start_margo_readme_sd_notify", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "start-margo/README.md", "source_location": null, "weight": 1.0}, {"source": "start_margo_readme_start_margo", "target": "wiki_configuration_mctl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "start-margo/README.md", "source_location": null, "weight": 1.0}, {"source": "start_margo_readme_start_margo", "target": "wiki_home_margo", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "start-margo/README.md", "source_location": null, "weight": 1.0}], "hyperedges": []}