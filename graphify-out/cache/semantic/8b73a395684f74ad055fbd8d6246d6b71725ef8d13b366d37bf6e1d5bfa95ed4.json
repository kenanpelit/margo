{"nodes": [{"id": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "label": "mvpn native Mullvad binary", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single standalone crate with no persistent state, no mshell service, no D-Bus IPC, no reactive store: the source of truth is the live mullvad daemon + on-disk files, so every invocation queries fresh. Privileged ops use non-interactive sudo -n, never pkexec (a polkit prompt from a keyboard-focused layer-shell window deadlocks)."}, {"id": "docs_superpowers_specs_2026_06_09_mvpn_design_engine", "label": "mvpn engine module (GTK-free, osc-mullvad port)", "file_type": "code", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_06_09_mvpn_design_panel", "label": "mvpn GTK4 layer-shell panel", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_06_09_mvpn_design_pill", "label": "mvpn declarative custom-widget pill", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Zero mshell code: uses the existing bars.widgets.custom_widgets mechanism; `mvpn status --pill` prints a leading #active line that mshell turns into the .custom-bar-widget.active CSS class tinted with var(--primary)."}, {"id": "docs_superpowers_specs_2026_06_09_mvpn_design_osc_mullvad", "label": "osc-mullvad bash script (replaced)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "mvpn CLI is one-to-one with osc-mullvad command names (drop-in) and reuses its file formats (favorites.txt, slot.state) and OSC_MULLVAD_* env vars so state carries over unchanged."}, {"id": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn_toml", "label": "mvpn.toml config", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "target": "docs_superpowers_specs_2026_06_09_mvpn_design_engine", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "target": "docs_superpowers_specs_2026_06_09_mvpn_design_panel", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "target": "docs_superpowers_specs_2026_06_09_mvpn_design_pill", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "target": "docs_superpowers_specs_2026_06_09_mvpn_design_osc_mullvad", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-09-mvpn-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_09_mvpn_design_mvpn", "target": "docs_superpowers_specs_2026_06_09_mvpn_desig