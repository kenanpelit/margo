{"nodes": [{"id": "docs_superpowers_specs_2026_06_01_sendkey_design_sendkey", "label": "sendkey dispatch action", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Native margo action chosen over ydotool/wtype: margo owns the seat keyboard and can forward synthetic key events to the focused surface; it does not implement virtual-keyboard (only virtual_pointer) so wtype cannot work, and ydotool needs a daemon+uinput. Self-contained, reusable, matches margo's first-party trajectory."}, {"id": "docs_superpowers_specs_2026_06_01_sendkey_design_parse_combo", "label": "parse_combo", "file_type": "code", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_06_01_sendkey_design_key_name_to_evdev", "label": "key_name_to_evdev table", "file_type": "code", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only layout-independent keys included in v1 (Tab, Page_Up, F-keys, arrows); letter symbols are layout-dependent and out of scope since tab navigation needs none of them."}, {"id": "docs_superpowers_specs_2026_06_01_sendkey_design_inject_combo", "label": "inject_combo (keyboard.input Forward)", "file_type": "code", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses FilterResult::Forward + fresh SERIAL_COUNTER serials so the synthetic events reach the client and do NOT re-trigger compositor binds."}, {"id": "docs_superpowers_specs_2026_06_01_sendkey_design_appid_matches", "label": "appid_matches", "file_type": "code", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_06_01_sendkey_design_gesturebind", "label": "gesturebind/keybind config for sendkey", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reuses standard bind/gesturebind arg slots (build_arg): combo->arg.v, appid-regex->arg.v2, fallback action->arg.v3; enables the user's old fusuma 3-finger browser tab-switch."}], "edges": [{"source": "docs_superpowers_specs_2026_06_01_sendkey_design_sendkey", "target": "docs_superpowers_specs_2026_06_01_sendkey_design_parse_combo", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_01_sendkey_design_sendkey", "target": "docs_superpowers_specs_2026_06_01_sendkey_design_inject_combo", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_01_sendkey_design_sendkey", "target": "docs_superpowers_specs_2026_06_01_sendkey_design_appid_matches", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-sendkey-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_06_01_sendkey_design_parse_combo", "target": "docs_superpowers_specs_2026_06_01_sendkey_design_key_name_to_evdev", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-06-01-sendkey-de